#!/usr/bin/env bash
# Build and flash firmware for a node role.
#
# Usage:
#   ./bin/flash <receiver-node|emitter-node> [port]
#
# Examples:
#   ./bin/flash receiver-node
#   ./bin/flash emitter-node /dev/ttyUSB0

set -euo pipefail

ROLE=${1:-}
PORT=${2:-}

if [[ -z "$ROLE" ]]; then
    echo "Error: node role required." >&2
    echo "Usage: $0 <receiver-node|emitter-node> [port]" >&2
    exit 1
fi

if [[ "$ROLE" != "receiver-node" && "$ROLE" != "emitter-node" ]]; then
    echo "Error: role must be 'receiver-node' or 'emitter-node', got '$ROLE'" >&2
    exit 1
fi

CONFIG="include/config.h"

if [[ ! -f "$CONFIG" ]]; then
    echo "Error: $CONFIG not found." >&2
    echo "Copy include/config.h.example to include/config.h and fill in your values." >&2
    exit 1
fi

# Warn if the example placeholder MAC is still in place
if grep -q "0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF" "$CONFIG"; then
    echo "Error: $CONFIG still contains the placeholder MAC address." >&2
    echo "Run ./bin/get-mac on each device, then set RECEIVER_NODE_MAC and EMITTER_NODE_MAC in $CONFIG." >&2
    exit 1
fi

UPLOAD_FLAGS=()
if [[ -n "$PORT" ]]; then
    UPLOAD_FLAGS+=(--upload-port "$PORT")
fi

echo "► Building $ROLE..."
pio run -e "$ROLE"

echo "► Flashing $ROLE..."
pio run -e "$ROLE" --target upload "${UPLOAD_FLAGS[@]}"

echo ""
echo "✓ $ROLE flashed successfully."
echo "  Run './bin/monitor${PORT:+ $PORT}' to open the serial console."
